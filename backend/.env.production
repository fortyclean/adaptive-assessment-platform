# ═══════════════════════════════════════════════════════
# EduAssess Backend — Production Environment Variables
# ═══════════════════════════════════════════════════════
# استبدل القيم المحاطة بـ <> بقيمك الحقيقية

NODE_ENV=production
PORT=3000

# MongoDB Atlas — استبدل بـ connection string من Atlas
MONGODB_URI=mongodb+srv://adaptive_user:<YOUR_ATLAS_PASSWORD>@cluster0.xxxxx.mongodb.net/adaptive_assessment?retryWrites=true&w=majority&appName=Cluster0

# Upstash Redis — استبدل بـ URL من Upstash
REDIS_URL=rediss://default:<YOUR_UPSTASH_TOKEN>@<YOUR_UPSTASH_HOST>.upstash.io:6379

# JWT Secrets — لا تغيّرها بعد النشر
JWT_SECRET=EduAssess_JWT_Secret_Key_2024_Production_Secure_32chars
REFRESH_TOKEN_SECRET=EduAssess_Refresh_Secret_Key_2024_Production_Secure
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=EduAssess_Enc_Key_2024_32chars!!

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# CORS — السماح لكل الأصول في مرحلة الاختبار
CORS_ORIGIN=*
